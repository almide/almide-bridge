// Tests for almide-bindgen

import json
import self as bindgen
import self.scaffolding as scaffolding

// ── Public API ──

test "version is not empty" {
  assert(string.len(bindgen.version()) > 0, "version must not be empty")
}

test "supported_languages has 20 entries" {
  assert_eq(list.len(bindgen.supported_languages()), 20)
}

// ── Shared helpers ──

test "get_str returns value" {
  let obj = json.object([("name", json.from_string("hello"))])
  assert_eq(bindgen.get_str(obj, "name"), "hello")
}

test "get_str returns empty for missing" {
  let obj = json.object([])
  assert_eq(bindgen.get_str(obj, "x"), "")
}

test "get_arr returns array" {
  let arr = json.array([json.from_int(1), json.from_int(2)])
  let obj = json.object([("items", arr)])
  assert_eq(list.len(bindgen.get_arr(obj, "items")), 2)
}

test "get_arr returns empty for missing" {
  let obj = json.object([])
  assert_eq(list.len(bindgen.get_arr(obj, "missing")), 0)
}

test "get_kind returns kind field" {
  let obj = json.object([("kind", json.from_string("record"))])
  assert_eq(bindgen.get_kind(obj), "record")
}

test "is_record true" {
  let types = [json.parse("{\"name\":\"P\",\"kind\":{\"kind\":\"record\",\"fields\":[]}}") ?? json.null()]
  assert_eq(bindgen.is_record("P", types), true)
}

test "is_record false" {
  let types = [json.parse("{\"name\":\"S\",\"kind\":{\"kind\":\"variant\",\"cases\":[]}}") ?? json.null()]
  assert_eq(bindgen.is_record("S", types), false)
}

test "is_variant true" {
  let types = [json.parse("{\"name\":\"S\",\"kind\":{\"kind\":\"variant\",\"cases\":[]}}") ?? json.null()]
  assert_eq(bindgen.is_variant("S", types), true)
}

// ── scaffolding (via import self.scaffolding) ──

test "scaffolding generates bridge helpers" {
  let iface = "{\"module\":\"t\",\"types\":[],\"functions\":[]}"
  let rust = "pub fn hello() -> String { \"hi\".to_string() }"
  let result = scaffolding.generate(iface, rust)
  assert(string.contains(result, "bridge_alloc"), "should have bridge_alloc")
  assert(string.contains(result, "bridge_free"), "should have bridge_free")
}

test "scaffolding preserves original code" {
  let iface = "{\"module\":\"t\",\"types\":[],\"functions\":[]}"
  let rust = "pub fn hello() -> String { \"hi\".to_string() }"
  let result = scaffolding.generate(iface, rust)
  assert(string.contains(result, "pub fn hello"), "should contain original function")
}

test "scaffolding generate_cargo" {
  let iface = "{\"module\":\"mylib\",\"types\":[],\"functions\":[]}"
  let result = scaffolding.generate_cargo(iface)
  assert(string.contains(result, "[package]"), "should have [package]")
  assert(string.contains(result, "cdylib"), "should have cdylib")
  assert(string.contains(result, "almide_mylib"), "should have lib name")
}

test "scaffolding with function generates bridge wrapper" {
  let iface = "{\"module\":\"t\",\"types\":[],\"functions\":[{\"name\":\"add\",\"params\":[{\"name\":\"a\",\"type\":{\"kind\":\"int\"}},{\"name\":\"b\",\"type\":{\"kind\":\"int\"}}],\"return\":{\"kind\":\"int\"}}]}"
  let rust = ""
  let result = scaffolding.generate(iface, rust)
  assert(string.contains(result, "bridge_add"), "should have bridge_add function")
  assert(string.contains(result, "extern \"C\""), "should have extern C")
}
